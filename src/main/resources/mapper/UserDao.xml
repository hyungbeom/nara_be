<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nara.nara_be.dao.UserDao">

    <resultMap id="userResultMap" type="User">
        <id property="userSeq" column="user_seq"/>
        <result property="userId" column="user_id"/>
        <result property="password" column="password"/>
        <result property="userName" column="user_name"/>
        <result property="useYn" column="use_yn"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="userColumns">
        user_seq,
        user_id,
        password,
        user_name,
        use_yn,
        created_at,
        updated_at
    </sql>

    <select id="findByUserId" resultMap="userResultMap">
        SELECT
        <include refid="userColumns"/>
        FROM progist.users
        WHERE user_id = #{userId}
    </select>

    <select id="existsByUserId" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM progist.users
        WHERE user_id = #{userId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="userSeq">
        INSERT INTO progist.users (
            user_id,
            password,
            user_name,
            use_yn
        ) VALUES (
            #{userId},
            #{password},
            #{userName},
            #{useYn}
        )
    </insert>

</mapper>
