<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.nara.nara_be.dao.SampleDao">

    <resultMap id="sampleResultMap" type="Sample">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
    </resultMap>

    <sql id="sampleColumns">
        id,
        name,
        description
    </sql>

    <select id="findAll" resultMap="sampleResultMap">
        SELECT
        <include refid="sampleColumns"/>
        FROM progist.sample
        ORDER BY id DESC
    </select>

    <select id="findById" resultMap="sampleResultMap">
        SELECT
        <include refid="sampleColumns"/>
        FROM progist.sample
        WHERE id = #{id}
    </select>

    <select id="existsById" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM progist.sample
        WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO progist.sample (
            name,
            description
        ) VALUES (
            #{name},
            #{description}
        )
    </insert>

    <update id="update">
        UPDATE progist.sample
        SET name = #{name},
            description = #{description}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM progist.sample
        WHERE id = #{id}
    </delete>

</mapper>
